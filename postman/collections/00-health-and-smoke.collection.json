{
  "info": {
    "_postman_id": "00000000-0000-4000-8000-000000000000",
    "name": "00 Health and Smoke",
    "description": "Smoke checks plus token setup. Run this first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Backend Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/",
        "description": "Public health check.",
        "auth": {
          "type": "noauth"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('backend is running', () => pm.response.to.have.status(200));",
              "pm.test('body confirms Smart Campus', () => pm.expect(pm.response.text()).to.include('Smart Campus'));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Login User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/auth/login",
        "description": "Stores accessToken and userId.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"USER\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "noauth"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('login succeeds', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.expect(data.token).to.be.a('string');",
              "const role = data.user && data.user.role;",
              "if (role === 'ADMIN') { pm.environment.set('adminToken', data.token); pm.environment.set('adminId', data.user.id); }",
              "if (role === 'USER') { pm.environment.set('accessToken', data.token); pm.environment.set('userId', data.user.id); }",
              "if (role === 'TECHNICIAN') { pm.environment.set('technicianToken', data.token); pm.environment.set('technicianId', data.user.id); }"
            ]
          }
        }
      ]
    },
