{
  "info": {
    "_postman_id": "11111111-1111-4000-8000-111111111111",
    "name": "01 Resources",
    "description": "Facilities and assets catalogue CRUD and validation checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "GET List Resources",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/resources",
        "description": "Public catalogue listing.",
        "auth": {
          "type": "noauth"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json()).to.be.an('array');"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Create Demo Resource",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/resources",
        "description": "Admin creates a bookable resource and stores resourceId/resourceName.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Demo Room {{$timestamp}}\",\n  \"type\": \"FACILITY\",\n  \"category\": \"MEETING_ROOM\",\n  \"capacity\": 20,\n  \"location\": \"Postman Test Block\",\n  \"availabilityStart\": \"08:00:00\",\n  \"availabilityEnd\": \"18:00:00\",\n  \"description\": \"Resource created by the Postman verification pack.\",\n  \"status\": \"ACTIVE\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "const data = pm.response.json();",
              "pm.environment.set('resourceId', data.id);",
              "pm.environment.set('resourceName', data.name);",
              "pm.expect(data.status).to.eql('ACTIVE');"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Resource By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/resources/{{resourceId}}",
        "description": "Fetches the created resource.",
        "auth": {
          "type": "noauth"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().id).to.eql(Number(pm.environment.get('resourceId')));"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT Update Demo Resource",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/resources/{{resourceId}}",
        "description": "Admin updates resource metadata.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{resourceName}}\",\n  \"type\": \"FACILITY\",\n  \"category\": \"MEETING_ROOM\",\n  \"capacity\": 24,\n  \"location\": \"Postman Test Block\",\n  \"availabilityStart\": \"08:30:00\",\n  \"availabilityEnd\": \"18:30:00\",\n  \"description\": \"Updated by Postman to verify PUT.\",\n  \"status\": \"ACTIVE\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().capacity).to.eql(24);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Create Invalid Resource",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/resources",
        "description": "Validation evidence.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"type\": \"FACILITY\",\n  \"category\": \"MEETING_ROOM\",\n  \"capacity\": -1,\n  \"location\": \"\",\n  \"status\": \"ACTIVE\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('validation returns 400', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Create Cleanup Resource",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/resources",
        "description": "Creates a throwaway resource for DELETE verification.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Cleanup Resource {{$timestamp}}\",\n  \"type\": \"EQUIPMENT\",\n  \"category\": \"PROJECTOR\",\n  \"capacity\": 1,\n  \"location\": \"IT Help Desk\",\n  \"availabilityStart\": \"09:00:00\",\n  \"availabilityEnd\": \"17:00:00\",\n  \"description\": \"Temporary resource used only for DELETE verification.\",\n  \"status\": \"ACTIVE\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "pm.environment.set('cleanupResourceId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE Cleanup Resource",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/resources/{{cleanupResourceId}}",
        "description": "Admin delete proof without removing the booking demo resource.",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 204', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ]
    }
  ]
}