{
  "info": {
    "_postman_id": "44444444-4444-4000-8000-444444444444",
    "name": "04 Notifications and Auth",
    "description": "Auth extras, user management, and notification panel requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "POST Signup Dynamic User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/auth/signup",
        "description": "Creates a dynamic user so repeated runs do not collide.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Dynamic User\",\n  \"email\": \"{{signupEmail}}\",\n  \"password\": \"ChangeMe123!\",\n  \"role\": \"USER\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "noauth"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('signupEmail', `postman.user.${Date.now()}@example.com`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.environment.set('newUserId', data.user.id);",
              "pm.expect(data.user.email).to.eql(pm.environment.get('signupEmail'));"
            ]
          }
        }
      ]
    },
    {
      "name": "GET List Notifications",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/notifications",
        "description": "Current user notification list after booking/ticket workflows."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json()).to.be.an('array');",
              "const items = pm.response.json(); if (items.length) pm.environment.set('notificationId', items[0].id);"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Unread Count",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/notifications/unread/count",
        "description": "Unread notification badge count."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json()).to.have.property('count');"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH Mark Notification Read",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": "{{baseUrl}}/api/notifications/{{notificationId}}/read",
        "description": "Mark one notification read. If no notificationId exists, 404 is acceptable for an isolated run."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200 or 404 when no notification exists', () => pm.expect([200,404]).to.include(pm.response.code));"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH Mark All Notifications Read",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": "{{baseUrl}}/api/notifications/read-all",
        "description": "Bulk read endpoint."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Users By Role Technician",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/users/role/TECHNICIAN",
        "description": "Admin user management lookup.",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json()).to.be.an('array');"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT Update Dynamic User Role",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/users/{{newUserId}}/role",
        "description": "Admin role update creates a notification for the changed user.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"TECHNICIAN\",\n  \"technicianSpecialty\": \"GENERAL\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().role).to.eql('TECHNICIAN');"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE Clear Notifications",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/notifications/clear",
        "description": "Optional cleanup for the current user notification panel."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 204', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ]
    }
  ]
}