        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceName\": \"{{resourceName}}\",\n  \"purpose\": \"Rejection workflow test\",\n  \"attendees\": 3,\n  \"startTime\": \"{{rejectBookingStartTime}}\",\n  \"endTime\": \"{{rejectBookingEndTime}}\"\n}",
