        "url": "{{baseUrl}}/api/bookings/{{rejectBookingId}}/reject",
        "description": "Admin rejection with reason.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Room reserved for examination preparation.\"\n}",
          "options": {
            "raw": {
