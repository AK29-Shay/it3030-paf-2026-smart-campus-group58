{
  "info": {
    "_postman_id": "22222222-2222-4000-8000-222222222222",
    "name": "02 Bookings",
    "description": "Booking request workflow, conflict handling, approval/rejection, QR, and check-in.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const base = new Date(Date.now() + 36 * 60 * 60 * 1000);",
          "base.setMinutes(0, 0, 0);",
          "const end = new Date(base.getTime() + 2 * 60 * 60 * 1000);",
          "const rejectStart = new Date(base.getTime() + 3 * 60 * 60 * 1000);",
          "const rejectEnd = new Date(base.getTime() + 4 * 60 * 60 * 1000);",
          "const fmt = d => d.toISOString().slice(0, 19);",
          "pm.environment.set('bookingStartTime', fmt(base));",
          "pm.environment.set('bookingEndTime', fmt(end));",
          "pm.environment.set('rejectBookingStartTime', fmt(rejectStart));",
          "pm.environment.set('rejectBookingEndTime', fmt(rejectEnd));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "POST Create Booking",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/bookings",
        "description": "Creates a pending booking for the authenticated user.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceName\": \"{{resourceName}}\",\n  \"purpose\": \"PAF viva rehearsal\",\n  \"attendees\": 6,\n  \"startTime\": \"{{bookingStartTime}}\",\n  \"endTime\": \"{{bookingEndTime}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.environment.set('bookingId', data.id);",
              "pm.expect(data.status).to.eql('PENDING');"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Create Conflicting Booking",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/bookings",
        "description": "Shows overlap protection for the same resource/time.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceName\": \"{{resourceName}}\",\n  \"purpose\": \"Overlapping booking conflict test\",\n  \"attendees\": 4,\n  \"startTime\": \"{{bookingStartTime}}\",\n  \"endTime\": \"{{bookingEndTime}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('conflict returns 409', () => pm.response.to.have.status(409));"
            ]
          }
        }
      ]
    },
    {
      "name": "GET My Bookings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/bookings/my-bookings",
