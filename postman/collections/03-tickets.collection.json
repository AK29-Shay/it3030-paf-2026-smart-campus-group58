{
  "info": {
    "_postman_id": "33333333-3333-4000-8000-333333333333",
    "name": "03 Tickets",
    "description": "Incident ticket workflow, technician assignment, status changes, and comments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "POST Create Ticket",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{baseUrl}}/api/tickets",
        "description": "Creates a ticket without image attachments. Add up to 3 images manually if needed.",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "title",
              "value": "Projector not powering on",
              "type": "text"
            },
            {
              "key": "description",
              "value": "The projector in the demo room does not power on before the viva rehearsal.",
              "type": "text"
            },
            {
              "key": "category",
              "value": "EQUIPMENT",
              "type": "text"
            },
            {
              "key": "priority",
              "value": "HIGH",
              "type": "text"
            },
            {
              "key": "createdBy",
              "value": "{{userId}}",
              "type": "text"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "const data = pm.response.json();",
              "pm.environment.set('ticketId', data.id);",
              "pm.expect(data.status).to.eql('OPEN');"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Ticket By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}",
        "description": "Fetch ticket details."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().id).to.eql(Number(pm.environment.get('ticketId')));"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT Assign Technician",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/assign",
        "description": "Admin assigns technician and creates notification.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assignedTo\": {{technicianId}},\n  \"reason\": \"Electrical equipment issue for demo room.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().assignedTo).to.eql(Number(pm.environment.get('technicianId')));"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Assignment History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/assignment-history",
        "description": "Audit trail for assignment.",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json()).to.be.an('array');"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT Update Ticket Status",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/status",
        "description": "Technician updates workflow status.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{technicianToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().status).to.eql('IN_PROGRESS');"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Add Comment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/comments",
        "description": "Ticket owner comment.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Please check the power cable and lamp indicator.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "pm.environment.set('commentId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT Update Comment",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/comments/{{commentId}}",
        "description": "Comment ownership update proof.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Please check the power cable, lamp indicator, and HDMI input.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().edited).to.eql(true);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Admin Reply",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/comments/{{commentId}}/reply",
        "description": "Admin reply creates notification for ticket owner.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Technician has been assigned and notified.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{adminToken}}",
              "type": "string"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "pm.environment.set('replyCommentId', pm.response.json().id);"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE Own Comment",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/comments/{{commentId}}",
        "description": "Delete own comment; child reply cleanup is handled by the backend."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 204', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ]
    }
  ]
}
